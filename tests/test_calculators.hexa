#!hexa strict
// hexa-cern/tests/test_calculators.hexa — per-pillar calculator regression.
//
// Runs each verify/calc_*.hexa script and asserts exit 0 + the per-script
// PASS sentinel. Aggregates results across all 4 calculators (cross-doc,
// wakefield, sigma cascade, classical) plus the falsifier checklist.

let HOME = env("HOME")

fn _root() -> str {
    let r = env("PETITE_CERN_ROOT")
    if r.len() > 0 { return r }
    let pwd = exec("pwd").trim()
    if pwd.len() > 0 { return pwd }
    return HOME + "/core/hexa-cern"
}

let ROOT = _root()
let HEXA = HOME + "/.hx/bin/hexa"

// (label, script_path, sentinel_token)
let CASES = [
    "cross_doc_audit.hexa|__HEXA_CERN_CROSS_DOC__ PASS",
    "calc_wakefield.hexa|__HEXA_CERN_WAKEFIELD__ PASS",
    "numerics_wakefield.hexa|__HEXA_CERN_NUMERICS_WAKEFIELD__ PASS",
    "calc_sigma_cascade.hexa|__HEXA_CERN_SIGMA_CASCADE__ PASS",
    "numerics_sigma_cascade.hexa|__HEXA_CERN_NUMERICS_SIGMA_CASCADE__ PASS",
    "calc_classical.hexa|__HEXA_CERN_CLASSICAL__ PASS",
    "numerics_classical.hexa|__HEXA_CERN_NUMERICS_CLASSICAL__ PASS",
    "numerics_cross_pillar.hexa|__HEXA_CERN_NUMERICS_CROSS_PILLAR__ PASS",
    "numerics_lhc_parity.hexa|__HEXA_CERN_NUMERICS_LHC_PARITY__ PASS",
    "numerics_lwfa_parity.hexa|__HEXA_CERN_NUMERICS_LWFA_PARITY__ PASS",
    "numerics_lattice_arithmetic.hexa|__HEXA_CERN_NUMERICS_LATTICE_ARITHMETIC__ PASS",
    "lint_numerics.hexa|__HEXA_CERN_LINT_NUMERICS__ PASS",
    "falsifier_check.hexa|__HEXA_CERN_FALSIFIER__ PASS",
]

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn run_one(case: str) -> bool {
    // case = "<filename>|<sentinel_token>"
    let parts = case.split("|")
    let fname = parts[0]
    let sentinel = parts[1]
    let path = ROOT + "/verify/" + fname
    let cmd = "PETITE_CERN_ROOT=" + shq(ROOT) + " " + shq(HEXA) + " run " + shq(path)
    let r = exec_with_status(cmd)
    let out = to_string(r[0])
    let code = r[1]
    let has_sent = out.find(sentinel) >= 0
    let pass = code == 0 && has_sent
    let mark = if pass { "PASS" } else { "FAIL" }
    println("  [" + mark + "] " + fname + "  (exit=" + str(code) + " sentinel=" + str(has_sent) + ")")
    return pass
}

fn main() {
    println("[test_calculators] running " + str(len(CASES)) + " calculator regressions")
    let mut ok = 0
    let mut fail = 0
    for c in CASES {
        if run_one(c) { ok = ok + 1 } else { fail = fail + 1 }
    }
    println("[test_calculators] " + str(ok) + "/" + str(len(CASES)) + " PASS")
    if fail > 0 {
        eprintln("__HEXA_CERN_TEST_CALCULATORS__ FAIL — " + str(fail) + " calculator(s) failed")
        exit(1)
    }
    println("__HEXA_CERN_TEST_CALCULATORS__ PASS — all calculators close")
    exit(0)
}
